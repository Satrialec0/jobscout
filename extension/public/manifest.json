{
  "manifest_version": 3,
  "name": "JobScout",
  "version": "0.1.0",
  "description": "Real-time job fit scoring as you browse",
  "permissions": ["activeTab", "storage", "tabs", "windows"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://www.indeed.com/*",
    "https://indeed.com/*",
    "https://hiring.cafe/*",
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*",
        "https://www.indeed.com/*",
        "https://indeed.com/*",
        "https://hiring.cafe/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "JobScout"
  },
  "web_accessible_resources": [
    {
      "resources": ["dashboard.html", "interview.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
